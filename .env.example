# ─────────────────────────────────────────────────────────────────────────────
# Premier Million — Template variables d'environnement
# ─────────────────────────────────────────────────────────────────────────────
# COPIE ce fichier en `.env` (gitignored) et remplis les valeurs.
# En production : configure ces variables dans Railway > Service > Variables.
# Voir docs/deployment.md pour les détails.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Base de données PostgreSQL ──────────────────────────────────────────────
# LOCAL  : URL d'un Postgres local (Docker, Postgres.app, etc.)
# RAILWAY: injecté automatiquement par le plugin Postgres — NE PAS définir manuellement
DATABASE_URL="postgresql://user:password@localhost:5432/premier_million?schema=public"

# ─── NextAuth.js ──────────────────────────────────────────────────────────────
# DOIT matcher l'URL exacte de l'app
#   - LOCAL  : http://localhost:3000
#   - RAILWAY: https://<ton-projet>.up.railway.app (ou ton domaine custom)
NEXTAUTH_URL="http://localhost:3000"

# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ─── Utilisateur solo MVP ─────────────────────────────────────────────────────
# Auth credentials hardcodée (MVP solo). En v2.0 sera remplacée par OAuth + allowlist.
SOLO_EMAIL="votre@email.fr"

# Hash bcrypt du mot de passe.
# IMPORTANT : échapper les $ avec \$ (dotenv-expand les interprète sinon).
# Générer avec :
#   node -e "require('bcryptjs').hash('monmotdepasse', 12).then(h => console.log(h.replace(/\$/g, '\\$')))"
SOLO_PASSWORD_HASH=\$2b\$12\$remplacer_par_le_vrai_hash

# ─── Anthropic API (Claude) ───────────────────────────────────────────────────
# Clé API server-side UNIQUEMENT — ne jamais exposer côté client
ANTHROPIC_API_KEY="sk-ant-..."

# Killswitch : mettre à `false` pour désactiver tous les appels Claude (cache renvoyé en fallback)
ANTHROPIC_ANALYSES_ENABLED=true

# Rate limit global (toutes analyses confondues, reset minuit UTC)
ANTHROPIC_MAX_CALLS_PER_DAY=10

# Tokens de sortie max par appel (~900 mots)
ANTHROPIC_MAX_OUTPUT_TOKENS=1200

# ─── Cron secret ──────────────────────────────────────────────────────────────
# Protège /api/cron/snapshot — appelé chaque jour par un cron Railway externe.
# Générer avec : openssl rand -base64 32
CRON_SECRET="generate-with: openssl rand -base64 32"

# ─── Prix marché (optionnel) ──────────────────────────────────────────────────
# CoinGecko a un free tier sans clé (rate-limit bas). Ajoute une clé demo si
# tu hit le rate-limit. Sans valeur ou "REMPLACER_PAR_TA_CLE", l'appel non
# authentifié est utilisé.
# COINGECKO_API_KEY="CG-..."

# ─── v1.2+ : Notifications email (Resend) — pas encore actif ─────────────────
# RESEND_API_KEY="re_..."

# ─── v2.0+ : OAuth providers — pas encore actif ──────────────────────────────
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
