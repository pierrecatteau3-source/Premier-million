# Base de données PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/premier_million?schema=public"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Utilisateur solo MVP
# Email de connexion
SOLO_EMAIL="votre@email.fr"
# Hash bcrypt du mot de passe — IMPORTANT: échapper les $ avec \$ car dotenv-expand les interprète sinon
# Générer avec: node -e "require('bcryptjs').hash('monmotdepasse', 12).then(h => console.log(h.replace(/\$/g, '\\$')))"
SOLO_PASSWORD_HASH=\$2b\$12\$remplacer_par_le_vrai_hash

# Anthropic API (server-side uniquement — ne jamais exposer côté client)
ANTHROPIC_API_KEY="sk-ant-..."

# Sécurités consommation Anthropic
# Mettre à false pour désactiver tous les appels Claude (mode urgence — retourne le cache)
ANTHROPIC_ANALYSES_ENABLED=true
# Nombre max d'appels API Claude toutes analyses confondues par jour (reset minuit UTC)
ANTHROPIC_MAX_CALLS_PER_DAY=10
# Nombre max de tokens de sortie par appel Claude (~900 mots)
ANTHROPIC_MAX_OUTPUT_TOKENS=1200

# Cron secret — protège la route /api/cron/snapshot (Vercel Cron Jobs)
# Générer avec: openssl rand -base64 32
# Ajouter également dans Vercel > Project > Settings > Environment Variables
CRON_SECRET="generate-with: openssl rand -base64 32"
