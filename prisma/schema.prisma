generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String                @id @default(cuid())
  email                    String                @unique
  name                     String?
  objectif                 Float                 @default(1000000)
  ageCible                 Int?
  epargneMensuelle         Float?
  /// { pea: 40, crypto: 20, immo: 30, autre: 10 }
  allocationCible          Json
  createdAt                DateTime              @default(now())
  ageActuel                Int?
  epargnePrecaution        Int?
  evolutionEpargne         Float?
  risqueMaxPerte           Float?
  niveauConnaissance       String?
  objectifCroissance       Float?
  /// [{ type, subtype, pct }] — allocation détaillée par type/sous-type
  allocationDetaillee      Json?
  epargnePrecautionMontant Float?
  /// Clés API courtiers (saisie manuelle, perso). null = non renseignée.
  xtbApiKey                String?
  bitpandaApiKey           String?
  achievements             UserAchievement[]
  analyses                 Analysis[]
  assets                   Asset[]
  contextDocuments         ContextDocument[]
  decisions                Decision[]
  recurringInvestments     RecurringInvestment[]
  transactions             Transaction[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())
  notified      Boolean  @default(false)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
}

model Asset {
  id                   String                @id @default(cuid())
  name                 String
  pilier               Pilier
  /// ex. "ETF", "Action", "Token", "SCI"
  type                 String
  userId               String
  createdAt            DateTime              @default(now())
  ticker               String?
  pricingMode          String                @default("manual")
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  recurringInvestments RecurringInvestment[]
  snapshots            Snapshot[]
  transactions         Transaction[]
}

model Snapshot {
  id        String   @id @default(cuid())
  assetId   String
  value     Float
  date      DateTime
  createdAt DateTime @default(now())
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, date])
  @@index([assetId, date])
}

model Analysis {
  id        String   @id @default(cuid())
  userId    String
  horizon   Horizon
  /// Contenu Markdown généré par Claude — mis en cache 30 jours
  content   String
  createdAt DateTime @default(now())
  /// "PORTFOLIO" = analyse personnalisée du portefeuille | "MARKET" = vision marché opportunités tech
  type      String   @default("PORTFOLIO")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, horizon, createdAt])
}

model Decision {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  description String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContextDocument {
  id        String   @id @default(cuid())
  userId    String
  filename  String
  mimeType  String
  /// Contenu texte extrait du fichier — injecté dans les prompts Claude
  content   String
  sizeBytes Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model RecurringInvestment {
  id         String   @id @default(cuid())
  userId     String
  assetId    String
  amount     Float
  frequency  String
  dayOfWeek  Int?
  dayOfMonth Int?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id             String   @id @default(cuid())
  userId         String
  assetId        String
  date           DateTime
  quantite       Float
  prixEntreeEur  Float
  montantInvesti Float
  source         String   @default("manuel")
  note           String?
  /// Identifiant de l'opération chez le courtier source (ex. id du trade BitPanda).
  /// null pour les saisies manuelles. Sert à dédoublonner les imports automatiques.
  externalId     String?
  createdAt      DateTime @default(now())
  asset          Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, externalId])
  @@index([assetId])
  @@index([userId])
}

enum Pilier {
  PEA
  CRYPTO
  IMMO
  AUTRE
  LIQUIDITE
}

enum Horizon {
  YEAR_1
  YEAR_3
  YEAR_5
  YEAR_10
}
